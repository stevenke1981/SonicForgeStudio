{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonicforge.local/schema/recipe-v1.json",
  "title": "SonicForge Recipe Definition v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "parameters"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "default"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "float",
              "int",
              "bool",
              "enum"
            ]
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          },
          "default": {},
          "unit": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
